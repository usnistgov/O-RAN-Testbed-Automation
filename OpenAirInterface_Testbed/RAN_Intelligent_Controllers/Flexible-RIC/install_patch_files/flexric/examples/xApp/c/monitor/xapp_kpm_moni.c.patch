+    strncpy(id_map[id_map_count].type, node_type, sizeof(id_map[0].type) - 1);
+    id_map[id_map_count].orig_id = orig_id;
+    id_map[id_map_count].mapped_id = new_id;
+    id_map_count++;
+  }
+
+  return new_id;
