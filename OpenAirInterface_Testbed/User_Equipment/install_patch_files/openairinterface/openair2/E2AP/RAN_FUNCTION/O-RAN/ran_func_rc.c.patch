 #include "../../flexric/src/agent/e2_agent_api.h"
 #include "openair2/E2AP/flexric/src/lib/sm/enc/enc_ue_id.h"
 #include "openair2/E2AP/flexric/src/sm/rc_sm/rc_sm_id.h"
+#include "../../flexric/src/sm/rc_sm/ie/rc_data_ie.h"
+#include "openair2/RRC/NR/rrc_gNB_du.h"
+#include "openair2/RRC/NR/rrc_gNB_mobility.h"
+#include "openair2/RRC/NR/rrc_gNB_UE_context.h"
+#include "openair2/RRC/NR/rrc_cell_management.h"
 
 #include <stdio.h>
 #include <unistd.h>
@@ -881,6 +886,110 @@ sm_ag_if_ans_t write_ctrl_rc_sm(void const* data)
 
   assert(ctrl->hdr.format == FORMAT_1_E2SM_RC_CTRL_HDR && "Indication Header Format received not valid");
   assert(ctrl->msg.format == FORMAT_1_E2SM_RC_CTRL_MSG && "Indication Message Format received not valid");
+  assert((ctrl->hdr.frmt_1.ctrl_act_id == 1 || ctrl->hdr.frmt_1.ctrl_act_id == 2) && "Currently only Handover Control and QoS flow mapping configuration supported");
+  const uint16_t style_type = ctrl->hdr.frmt_1.ric_style_type;
+  const uint16_t act_id = ctrl->hdr.frmt_1.ctrl_act_id;
+
+  if (style_type == 3 && act_id == 1) {
+    // 7.6.4 CONTROL Service Style 3: Connected Mode Mobility Control
+    // 8.4.4.1 Handover Control
+    printf("[E2SM-RC] Handover Control configuration\n");
+
+    // Extract UE ID
+    const ue_id_e2sm_t *ue_id = &ctrl->hdr.frmt_1.ue_id;
+    if (ue_id->type != GNB_UE_ID_E2SM) {
+      printf("[E2SM-RC] Unsupported UE ID for Handover Control\n");
+    } else {
+      uint32_t rrc_ue_id = (uint32_t)*ue_id->gnb.ran_ue_id;
+      const seq_ran_param_t *ran_param = ctrl->msg.frmt_1.ran_param;
+      // Find Target Primary Cell ID
+      for (size_t i = 0; i < ctrl->msg.frmt_1.sz_ran_param; i++) {
+        if (ran_param[i].ran_param_id == TARGET_PRIMARY_CELL_ID_8_4_4_1) { // Target Primary Cell ID
+          if (ran_param[i].ran_param_val.type != STRUCTURE_RAN_PARAMETER_VAL_TYPE)
+            continue;
+
+          const ran_param_struct_t *s1 = ran_param[i].ran_param_val.strct; // Target Primary Cell ID
+          if (s1->sz_ran_param_struct == 0)
+            continue;
+
+          // CHOICE Target Cell (ID 2)
+          const seq_ran_param_t *p2 = &s1->ran_param_struct[0];
+          if (p2->ran_param_id != CHOICE_TARGET_CELL_8_4_4_1 || p2->ran_param_val.type != STRUCTURE_RAN_PARAMETER_VAL_TYPE)
+            continue;
+
+          const ran_param_struct_t *s2 = p2->ran_param_val.strct; // CHOICE Target Cell
+          if (s2->sz_ran_param_struct == 0)
+            continue;
+
+          // NR Cell (ID 3)
+          const seq_ran_param_t *p3 = &s2->ran_param_struct[0];
+          if (p3->ran_param_id != NR_CELL_8_4_4_1 || p3->ran_param_val.type != STRUCTURE_RAN_PARAMETER_VAL_TYPE)
+            continue;
+
+          const ran_param_struct_t *s3 = p3->ran_param_val.strct; // NR Cell
+          if (s3->sz_ran_param_struct == 0)
+            continue;
+
+          // NR CGI (ID 4)
+          const seq_ran_param_t *p4 = &s3->ran_param_struct[0];
+          if (p4->ran_param_id != NR_CGI_8_4_4_1 || p4->ran_param_val.type != ELEMENT_KEY_FLAG_FALSE_RAN_PARAMETER_VAL_TYPE)
+            continue;
+
+          // Extract cell ID from Octet String
+          if (p4->ran_param_val.flag_false->octet_str_ran.len > 0) {
+            // Cell ID from Octet String
+            uint8_t *buf = p4->ran_param_val.flag_false->octet_str_ran.buf;
+            int len = p4->ran_param_val.flag_false->octet_str_ran.len;
+
+            uint64_t target_cell_id = 0;
+            if (len == 8) {
+              // Extract 36-bit NCI from NR CGI (first three are PLMN)
+              target_cell_id = ((uint64_t)buf[3] << 28) | ((uint64_t)buf[4] << 20) | ((uint64_t)buf[5] << 12)
+                               | ((uint64_t)buf[6] << 4) | ((uint64_t)buf[7] >> 4);
+            } else {
+              // Otherwise, unpack integer from bytes
+              for (int i = 0; i < len; i++) {
+                target_cell_id = (target_cell_id << 8) | buf[i];
+              }
+            }
+
+            // // Map xApp indexes to OAI full Cell IDs
+            // if (target_cell_id == 1) target_cell_id = 11111111;
+            // else if (target_cell_id == 2) target_cell_id = 11111112;
+
+            // Trigger Handover
+            printf("[E2SM-RC] Triggering Handover for UE %u to Cell %lu\n", rrc_ue_id, target_cell_id);
+
+#ifdef NGRAN_GNB_CUCP
+            gNB_RRC_INST *rrc = RC.nrrrc[0];
+            rrc_gNB_ue_context_t *ue_context = rrc_gNB_get_ue_context(rrc, rrc_ue_id);
+
+            if (ue_context) {
+              gNB_RRC_UE_t *ue = &ue_context->ue_context;
+              if (ue->serving_cells.size > 0) {
+                ue_serving_cell_t *sc = (ue_serving_cell_t *)seq_arr_at(&ue->serving_cells, 0);
+                void *source_cell = get_cell_by_cell_id(&rrc->cells, sc->nci);
+                void *target_cell = get_cell_by_cell_id(&rrc->cells, target_cell_id);
+
+                if (source_cell && target_cell) {
+                  nr_rrc_trigger_f1_ho(rrc, ue, source_cell, target_cell);
+                } else {
+                  printf("[E2SM-RC] Handover failed: Source or Target Cell not found\n");
+                }
+              } else {
+                printf("[E2SM-RC] Handover failed: UE %u has no serving cells\n", rrc_ue_id);
+              }
+            } else {
+              printf("[E2SM-RC] Handover failed: UE Context not found for ID %u\n", rrc_ue_id);
+            }
+#else
+            printf("[E2SM-RC] Handover not supported for this node type\n");
+#endif
+          }
+        }
+      }
+    }
+  } else if (act_id == 2) {
   assert(ctrl->hdr.frmt_1.ctrl_act_id == 2 && "Currently only QoS flow mapping configuration supported");
 
   printf("QoS flow mapping configuration\n");
@@ -916,7 +1025,7 @@ sm_ag_if_ans_t write_ctrl_rc_sm(void const* data)
   assert(dir == 0 || dir == 1);
 
   printf("qfi = %ld, dir %ld \n", qfi, dir);
-
+  }
 
   sm_ag_if_ans_t ans = {.type = CTRL_OUTCOME_SM_AG_IF_ANS_V0};
