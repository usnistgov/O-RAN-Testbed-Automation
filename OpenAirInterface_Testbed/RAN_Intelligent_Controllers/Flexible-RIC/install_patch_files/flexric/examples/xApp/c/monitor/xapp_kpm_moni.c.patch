+      return id_map[i].mapped_id;
+    }
+  }
+
+  int new_id = 1;
+  for (int i = 0; i < id_map_count; i++) {
+    if (strcmp(id_map[i].type, node_type) == 0) {
+      new_id++;
+    }
+  }
+
